---
interface Project {
  title: string;
  description: string;
  image: string;
  technologies: string[];
  liveUrl: string;
  githubUrl?: string;
}

const projects: Project[] = [
  {
    title: 'GeoTampico · Plataforma de mapeo territorial',
    description:
      'Aplicación full stack para segmentación y análisis geoespacial del municipio de Tampico, con dashboard interactivo y autenticación JWT.',
    image: '/image.png',
    technologies: ['React', 'Node.js', 'PostgreSQL', 'Docker', 'Redis', 'JWT'],
    liveUrl: 'http://geotampico.com.mx/',
    githubUrl: 'https://github.com/mael098/proyecto'
  },
  {
    title: 'Plataforma de jornadas académicas',
    description:
      'Sistema web para registrar y visualizar jornadas, con control de información, métricas y reportes para toma de decisiones.',
    image: '/image copy.png',
    technologies: ['Next.js', 'TypeScript', 'PostgreSQL', 'Tailwind CSS'],
    liveUrl: 'https://jornadas-sistemas-2025.vercel.app/',
    githubUrl: 'https://github.com/mael098/jornadas'
  }
];
---

<section id="projects" class="projects-section">
  <div class="container">
    <header class="section-header">
      <span class="section-tag">PORTAFOLIO</span>
      <h2 class="section-title">Proyectos destacados</h2>
      <p class="section-description">
        Productos desplegados con enfoque en arquitectura, experiencia de usuario y ejecución técnica profesional.
      </p>
    </header>

    <div class="projects-grid">
      {projects.map((project) => (
        <article class="project-card">
          <img src={project.image} alt={project.title} class="project-image" />
          <div class="project-content">
            <h3>{project.title}</h3>
            <p>{project.description}</p>

            <div class="tech-tags">
              {project.technologies.map((tech) => (
                <span>{tech}</span>
              ))}
            </div>

            <div class="project-links">
              <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="link-primary">
                Ver demo
              </a>
              {project.githubUrl && (
                <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="link-secondary">
                  Código
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-section {
    padding: 110px 0;
    background: linear-gradient(180deg, var(--secondary) 0%, var(--background) 100%);
  }

  .section-header {
    text-align: center;
    margin-bottom: 44px;
  }

  .section-tag {
    display: inline-block;
    padding: 6px 14px;
    border-radius: 999px;
    border: 1px solid rgba(244, 162, 97, 0.35);
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
  }

  .section-title {
    font-size: clamp(1.85rem, 4vw, 3rem);
    margin-bottom: 12px;
  }

  .section-description {
    color: var(--text-secondary);
    max-width: 66ch;
    margin: 0 auto;
  }

  .projects-grid {
    display: grid;
    gap: 16px;
  }

  .project-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border-color);
    background: var(--background-card);
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    min-height: 260px;
  }

  .project-content {
    padding: 22px;
    display: flex;
    flex-direction: column;
  }

  .project-content h3 {
    font-size: 1.22rem;
    margin-bottom: 10px;
  }

  .project-content p {
    color: var(--text-secondary);
    margin-bottom: 14px;
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .tech-tags span {
    font-size: 0.78rem;
    border: 1px solid var(--border-color);
    border-radius: 999px;
    padding: 4px 10px;
    color: var(--text-secondary);
  }

  .project-links {
    display: flex;
    gap: 10px;
    margin-top: auto;
  }

  .project-links a {
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: 999px;
    padding: 10px 16px;
  }

  .link-primary {
    background: linear-gradient(135deg, var(--accent), var(--accent-dark));
    color: #fff;
  }

  .link-secondary {
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    background: transparent;
  }

  @media (max-width: 920px) {
    .projects-section {
      padding: 80px 0;
    }

    .project-card {
      grid-template-columns: 1fr;
    }

    .project-image {
      min-height: 200px;
    }
  }
</style>
