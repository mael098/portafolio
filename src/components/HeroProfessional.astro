---
const metrics = [
  { value: '2+', label: 'Proyectos web en producción' },
  { value: '10+', label: 'Tecnologías utilizadas en proyectos' },
  { value: '100%', label: 'Enfoque en calidad de entrega' }
];
---

<section id="hero" class="hero-section">
  <div class="container hero-grid">
    <div class="hero-copy">
      <span class="hero-badge">Disponible para vacantes y colaboración</span>
      <h1 class="hero-title">
        Iván Asdrúbal Villegas Espinosa
      </h1>
      <p class="hero-role">Ingeniero en Sistemas Computacionales · Full Stack Developer</p>
      <p class="hero-description">
        Desarrollo aplicaciones web modernas con enfoque en arquitectura limpia, experiencia de usuario y mantenibilidad.
        Me interesa construir productos estables, escalables y útiles para negocio.
      </p>

      <div class="hero-actions">
        <a href="#projects" class="btn-primary">Ver proyectos</a>
        <a href="#contact" class="btn-secondary">Contactar</a>
      </div>
    </div>

    <aside class="hero-panel">
      <h2 class="panel-title">Perfil técnico</h2>
      <ul class="panel-list">
        <li>Frontend: React, Next.js, Astro, TypeScript</li>
        <li>Backend: Node.js, APIs REST, autenticación JWT</li>
        <li>Bases de datos: PostgreSQL, Prisma, Redis</li>
        <li>Flujo profesional: Git, Docker, Linux</li>
      </ul>

      <div class="metrics-grid">
        {metrics.map((metric) => (
          <article class="metric-card">
            <p class="metric-value">{metric.value}</p>
            <p class="metric-label">{metric.label}</p>
          </article>
        ))}
      </div>
    </aside>
  </div>
</section>

<style>
  .hero-section {
    min-height: 95vh;
    display: flex;
    align-items: center;
    padding: 120px 0 72px;
    background: radial-gradient(circle at 85% 20%, rgba(244, 162, 97, 0.14), transparent 36%),
      var(--background);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 30px;
    align-items: center;
  }

  .hero-badge {
    display: inline-block;
    padding: 8px 14px;
    border-radius: 999px;
    border: 1px solid rgba(34, 197, 94, 0.35);
    color: #22c55e;
    font-size: 0.8rem;
    font-weight: 700;
    margin-bottom: 18px;
  }

  .hero-title {
    font-size: clamp(2rem, 4.6vw, 3.7rem);
    line-height: 1.08;
    margin-bottom: 12px;
  }

  .hero-role {
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 14px;
  }

  .hero-description {
    color: var(--text-secondary);
    max-width: 62ch;
    margin-bottom: 26px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 11px 20px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    border: 1px solid transparent;
    transition: transform 0.2s ease;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent), var(--accent-dark));
    color: #fff;
  }

  .btn-secondary {
    color: var(--text-primary);
    border-color: var(--border-color);
    background: var(--background-card);
  }

  .btn-primary:hover,
  .btn-secondary:hover {
    transform: translateY(-2px);
  }

  .hero-panel {
    background: var(--background-card);
    border: 1px solid var(--border-color);
    border-radius: 18px;
    padding: 22px;
  }

  .panel-title {
    font-size: 1.1rem;
    margin-bottom: 12px;
  }

  .panel-list {
    margin: 0;
    padding-left: 20px;
    color: var(--text-secondary);
    display: grid;
    gap: 8px;
    margin-bottom: 20px;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .metric-card {
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 12px 10px;
    text-align: center;
    background: rgba(0, 0, 0, 0.14);
  }

  html.light-mode .metric-card {
    background: rgba(0, 0, 0, 0.02);
  }

  .metric-value {
    font-size: 1.2rem;
    font-weight: 800;
    margin-bottom: 4px;
    color: var(--accent);
  }

  .metric-label {
    font-size: 0.74rem;
    color: var(--text-secondary);
    line-height: 1.35;
  }

  @media (max-width: 920px) {
    .hero-section {
      padding: 96px 0 56px;
      min-height: auto;
    }

    .hero-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .hero-panel {
      order: -1;
    }
  }

  @media (max-width: 600px) {
    .metrics-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
