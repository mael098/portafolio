---
const groups = [
  {
    title: 'Frontend',
    items: ['React', 'Next.js', 'Astro', 'TypeScript', 'Tailwind CSS']
  },
  {
    title: 'Backend',
    items: ['Node.js', 'Express', 'REST APIs', 'JWT', 'Prisma']
  },
  {
    title: 'Base de datos',
    items: ['PostgreSQL', 'MySQL', 'MongoDB', 'Redis']
  },
  {
    title: 'Dev workflow',
    items: ['Git', 'Docker', 'Linux', 'Postman', 'VS Code']
  }
];
---

<section id="skills" class="skills-section">
  <div class="container">
    <header class="section-header">
      <span class="section-tag">TECNOLOGÍAS</span>
      <h2 class="section-title">Stack técnico</h2>
      <p class="section-description">
        Herramientas y tecnologías que utilizo para diseñar, desarrollar y desplegar aplicaciones web robustas.
      </p>
    </header>

    <div class="stack-grid">
      {groups.map((group) => (
        <article class="stack-card">
          <h3>{group.title}</h3>
          <ul>
            {group.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-section {
    padding: 110px 0;
    background: linear-gradient(180deg, var(--background) 0%, var(--secondary) 100%);
  }

  .section-header {
    text-align: center;
    margin-bottom: 42px;
  }

  .section-tag {
    display: inline-block;
    padding: 6px 14px;
    border-radius: 999px;
    border: 1px solid rgba(244, 162, 97, 0.35);
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
  }

  .section-title {
    font-size: clamp(1.85rem, 4vw, 3rem);
    margin-bottom: 12px;
  }

  .section-description {
    color: var(--text-secondary);
    max-width: 66ch;
    margin: 0 auto;
  }

  .stack-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .stack-card {
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 20px;
    background: var(--background-card);
  }

  .stack-card h3 {
    font-size: 1.1rem;
    margin-bottom: 10px;
    color: var(--text-primary);
  }

  .stack-card ul {
    margin: 0;
    padding-left: 18px;
    color: var(--text-secondary);
    display: grid;
    gap: 8px;
  }

  @media (max-width: 760px) {
    .skills-section {
      padding: 80px 0;
    }

    .stack-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
