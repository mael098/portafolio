---
const experience = [
  {
    role: 'Desarrollador Full Stack',
    company: 'Proyectos independientes y académicos',
    period: '2025 - Actualidad',
    points: [
      'Construcción de aplicaciones web completas con Next.js, TypeScript y Prisma.',
      'Implementación de APIs con validación, manejo de errores y estructura escalable.',
      'Entrega de interfaces responsivas enfocadas en usabilidad y rendimiento.'
    ]
  },
  {
    role: 'Desarrollador de plataformas digitales',
    company: 'Servicio social y concursos de innovación',
    period: '2024 - 2025',
    points: [
      'Participación en Geotampico para análisis y visualización geoespacial.',
      'Diseño de prototipos funcionales para evaluación académica e industrial.',
      'Colaboración en equipos multidisciplinarios con comunicación técnica clara.'
    ]
  }
];

const education = [
  {
    degree: 'Ingeniería en Sistemas Computacionales',
    institution: 'Instituto Tecnológico de Altamira',
    period: '2022 - En curso',
    detail: 'Promedio 9.2 / 10 · participación en talleres de desarrollo web.'
  },
  {
    degree: 'Técnico en Programación',
    institution: 'CBTis 105',
    period: '2018 - 2022',
    detail: 'Base sólida en lógica de programación, web y bases de datos.'
  }
];
---

<section id="experience" class="experience-section">
  <div class="container">
    <header class="section-header">
      <span class="section-tag">TRAYECTORIA</span>
      <h2 class="section-title">Experiencia profesional</h2>
      <p class="section-description">
        Formación técnica y proyectos reales enfocados en construir software funcional, mantenible y orientado a resultados.
      </p>
    </header>

    <div class="timeline">
      {experience.map((job) => (
        <article class="timeline-item">
          <div class="item-head">
            <h3>{job.role}</h3>
            <span>{job.period}</span>
          </div>
          <p class="item-company">{job.company}</p>
          <ul>
            {job.points.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <div class="education-grid">
      {education.map((edu) => (
        <article class="education-card">
          <h3>{edu.degree}</h3>
          <p class="institution">{edu.institution}</p>
          <p class="period">{edu.period}</p>
          <p class="detail">{edu.detail}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .experience-section {
    padding: 110px 0;
    background: linear-gradient(180deg, var(--background) 0%, var(--secondary) 100%);
  }

  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-tag {
    display: inline-block;
    padding: 6px 14px;
    border-radius: 999px;
    border: 1px solid rgba(244, 162, 97, 0.35);
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
  }

  .section-title {
    font-size: clamp(1.85rem, 4vw, 3rem);
    margin-bottom: 12px;
  }

  .section-description {
    color: var(--text-secondary);
    max-width: 68ch;
    margin: 0 auto;
  }

  .timeline {
    display: grid;
    gap: 16px;
    margin-bottom: 26px;
  }

  .timeline-item {
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 20px;
    background: var(--background-card);
  }

  .item-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 4px;
  }

  .item-head h3 {
    font-size: 1.2rem;
  }

  .item-head span {
    color: var(--text-secondary);
    font-size: 0.82rem;
    border: 1px solid var(--border-color);
    border-radius: 999px;
    padding: 5px 10px;
    white-space: nowrap;
  }

  .item-company {
    color: var(--accent);
    margin-bottom: 10px;
    font-weight: 600;
  }

  .timeline-item ul {
    margin: 0;
    padding-left: 18px;
    color: var(--text-secondary);
    display: grid;
    gap: 8px;
  }

  .education-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .education-card {
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 18px;
    background: var(--background-card);
  }

  .education-card h3 {
    font-size: 1.1rem;
    margin-bottom: 6px;
  }

  .institution {
    color: var(--accent);
    margin-bottom: 4px;
    font-weight: 600;
  }

  .period,
  .detail {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .detail {
    margin-top: 8px;
  }

  @media (max-width: 760px) {
    .experience-section {
      padding: 80px 0;
    }

    .education-grid {
      grid-template-columns: 1fr;
    }

    .item-head {
      flex-direction: column;
    }
  }
</style>
