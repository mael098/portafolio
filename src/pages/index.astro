---
import Layout from "../layouts/Layout.astro";
import "./_estilos.css";
import HeroProfessional from "../components/HeroProfessional.astro";
import ProjectShowcase from "../components/ProjectShowcase.astro";
import TechStack from "../components/TechStack.astro";
import Experience from "../components/Experience.astro";
---

<Layout title="Ivan Asdrubal Villegas Espinosa | Ingeniero en Sistemas Computacionales">
  <!-- Script para prevenir parpadeo del tema -->
  <script is:inline>
    (function() {
      const savedTheme = localStorage.getItem('theme');
      const systemTheme = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      const theme = savedTheme || systemTheme;
      if (theme === 'light') {
        document.documentElement.classList.add('light-mode');
      }
    })();
  </script>

  <div id="loader-overlay">
    <span class="loader-text">Bienvenido</span>
  </div>
  
  <!-- Navbar moderna y fija -->
  <nav class="modern-navbar">
    <div class="nav-container">
      <div class="nav-brand">
        <span class="brand-text">IV</span>
      </div>
      <div class="nav-links">
        <a href="#hero">Inicio</a>
        <a href="#experience">Experiencia</a>
        <a href="#projects">Proyectos</a>
        <a href="#skills">Tecnologías</a>
        <a href="#contact">Contacto</a>
      </div>
      <button class="theme-toggle" aria-label="Toggle theme">🌙</button>
    </div>
  </nav>

  <main>
    <!-- Hero Section Profesional -->
    <HeroProfessional />

    <!-- Experiencia y Logros -->
    <Experience />

    <!-- Proyectos Desplegados -->
